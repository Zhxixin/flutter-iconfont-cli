{
  "name": "iconfont-cli",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cpx \"src/templates/*\" dist/templates",
    "start": "node dist/index.js"
  },
  "bin": {
    "iconfont-cli": "dist/index.js"
  },
  "dependencies": {
    "colors": "^1.3.3",
    "glob": "^7.1.4",
    "iconfont-parser": "^1.0.0",
    "lodash": "^4.17.15",
    "minimist": "^1.2.5",
    "mkdirp": "^0.5.1",
    "tslib": "^1.10.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/glob": "^7.1.1",
    "@types/lodash": "^4.14.137",
    "@types/minimist": "^1.2.0",
    "@types/mkdirp": "^0.5.2",
    "@types/node": "^22.10.7",
    "@types/react": "^16.9.2",
    "@types/xml2js": "^0.4.14",
    "cpx": "^1.5.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^8.3.0",
    "typescript": "^5.9.2",
    "webpack-cli": "^6.0.1",
    "webpack-node-externals": "^3.0.0"
  },
  "pkg": {
    "scripts": [
      "dist/**/*"
    ],
    "assets": [
      "dist/templates/*",
      "dist/components/*"
    ],
    "targets": [
      "node16-win-x64"
    ]
  }
}
